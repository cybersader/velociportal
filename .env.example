# Headscale control server URL (e.g. https://headscale.example.com)
HEADSCALE_URL=

# Headscale API key (generate with: headscale apikeys create)
HEADSCALE_API_KEY=

# Nginx Proxy Manager URL (e.g. http://npm:81)
NPM_URL=

# NPM admin email
NPM_EMAIL=admin@example.com

# NPM admin password
NPM_PASSWORD=

# Address to listen on (default: 127.0.0.1:8080)
# Set to 0.0.0.0:8080 only if running in Docker with proper network isolation
# LISTEN_ADDR=127.0.0.1:8080

# How often to poll upstream APIs (default: 30s)
# POLL_INTERVAL=30s

# CIDR of the trusted reverse proxy that provides Tailscale identity headers
# Common values:
#   127.0.0.1/32     - loopback only (default)
#   100.64.0.0/10    - Tailscale CGNAT range
#   172.17.0.0/16    - Docker bridge network
# TRUSTED_PROXY_CIDR=127.0.0.1/32
